{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DNA v1.0 Schema",
  "description": "Schema for validating legacy DNA v1.0 objects (4D: L/C/K/σL)",
  "type": "object",
  "required": ["l", "c", "k", "l_std_dev"],
  "properties": {
    "l": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Average lightness (0-100)"
    },
    "c": {
      "type": "number",
      "minimum": 0,
      "maximum": 150,
      "description": "Average chroma (0-150)"
    },
    "k": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Contrast / dynamic range"
    },
    "l_std_dev": {
      "type": "number",
      "minimum": 0,
      "maximum": 50,
      "description": "Lightness standard deviation"
    }
  },
  "additionalProperties": true
}
