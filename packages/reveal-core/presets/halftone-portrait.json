{
  "id": "halftone-portrait",
  "name": "Halftone Portrait",
  "description": "Optimized for portraits with halftone blacks (e.g., JethroAsMonroe)",
  "settings": {
    "engineType": "reveal",
    "centroidStrategy": "SALIENCY",
    "lWeight": 2.0,
    "cWeight": 0.4,
    "blackBias": 10.0,
    "substrateMode": "white",
    "substrateTolerance": 2.5,
    "vibrancyMode": "exponential",
    "vibrancyBoost": 1.8,
    "highlightThreshold": 85,
    "highlightBoost": 2.0,
    "enablePaletteReduction": true,
    "paletteReduction": 6.0,
    "hueLockAngle": 10,
    "shadowPoint": 8,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": true,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none",
    "maskProfile": "Gray Gamma 2.2"
  }
}