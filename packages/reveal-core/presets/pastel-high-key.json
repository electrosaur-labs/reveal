{
  "id": "pastel-high-key",
  "name": "Pastel / High-Key",
  "description": "Light and airy with soft colors for pastel and high-key images",
  "settings": {
    "engineType": "reveal",
    "centroidStrategy": "SALIENCY",
    "lWeight": 1.0,
    "cWeight": 1.8,
    "blackBias": 0.0,
    "substrateMode": "white",
    "substrateTolerance": 5.0,
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.1,
    "highlightThreshold": 94,
    "highlightBoost": 1.4,
    "enablePaletteReduction": true,
    "paletteReduction": 6.0,
    "hueLockAngle": 12,
    "shadowPoint": 20,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": true,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none",
    "maskProfile": "Gray Gamma 2.2"
  }
}
