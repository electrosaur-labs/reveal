{
  "id": "vibrant-graphic",
  "name": "Vibrant Graphic",
  "description": "Optimized for high-chroma graphics (e.g., 0B9A4230)",
  "settings": {
    "engineType": "reveal",
    "centroidStrategy": "SALIENCY",
    "lWeight": 1.0,
    "cWeight": 2.5,
    "blackBias": 0.0,
    "substrateMode": "auto",
    "substrateTolerance": 2.0,
    "vibrancyMode": "aggressive",
    "vibrancyBoost": 2.0,
    "highlightThreshold": 90,
    "highlightBoost": 1.6,
    "enablePaletteReduction": true,
    "paletteReduction": 12.0,
    "hueLockAngle": 22,
    "shadowPoint": 15,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": true,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none",
    "maskProfile": "Gray Gamma 2.2"
  }
}
