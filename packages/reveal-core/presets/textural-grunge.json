{
  "id": "textural-grunge",
  "name": "Textural / Grunge",
  "description": "Emphasizes texture and tonal variation for grunge and textural images",
  "settings": {
    "engineType": "reveal",
    "centroidStrategy": "SALIENCY",
    "lWeight": 1.8,
    "cWeight": 1.2,
    "blackBias": 5.0,
    "substrateMode": "auto",
    "substrateTolerance": 2.5,
    "vibrancyMode": "aggressive",
    "vibrancyBoost": 1.5,
    "highlightThreshold": 92,
    "highlightBoost": 2.0,
    "enablePaletteReduction": true,
    "paletteReduction": 6.0,
    "hueLockAngle": 12,
    "shadowPoint": 10,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": false,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none",
    "maskProfile": "Gray Gamma 2.2"
  }
}
