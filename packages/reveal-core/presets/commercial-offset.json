{
  "id": "commercial-offset",
  "name": "Commercial Offset",
  "description": "Optimized for commercial offset printing with precise color control",
  "settings": {
    "engineType": "balanced",
    "centroidStrategy": "VOLUMETRIC",
    "lWeight": 1.1,
    "cWeight": 1.2,
    "blackBias": 4.0,
    "substrateMode": "white",
    "substrateTolerance": 2.0,
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.0,
    "highlightThreshold": 96,
    "highlightBoost": 1.5,
    "enablePaletteReduction": true,
    "paletteReduction": 6.0,
    "hueLockAngle": 10,
    "shadowPoint": 12,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none"
  }
}
