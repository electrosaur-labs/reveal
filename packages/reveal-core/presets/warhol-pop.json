{
  "id": "warhol-pop",
  "name": "Warhol Pop",
  "description": "Flat color mapping for iconic, pop-art style distributions.",
  "settings": {
    "engineType": "reveal",
    "centroidStrategy": "SALIENCY",
    "lWeight": 0.8,
    "cWeight": 1.5,
    "blackBias": 2.0,
    "substrateMode": "auto",
    "substrateTolerance": 5.0,
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.2,
    "highlightThreshold": 95,
    "highlightBoost": 1.0,
    "enablePaletteReduction": true,
    "paletteReduction": 12.0,
    "hueLockAngle": 30,
    "shadowPoint": 5,
    "colorMode": "color",
    "targetColorsSlider": 5,
    "preserveWhite": false,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": false,
    "ditherType": "none",
    "maskProfile": "Gray Gamma 2.2"
  }
}
