{
  "id": "technical-enamel",
  "name": "Industrial Enamel",
  "description": "High-opacity mapping for 59000 series inks on metal and glass.",
  "settings": {
    "engineType": "reveal",
    "centroidStrategy": "VOLUMETRIC",
    "lWeight": 0.5,
    "cWeight": 1.2,
    "blackBias": 8.0,
    "substrateMode": "none",
    "substrateTolerance": 2.5,
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.8,
    "highlightThreshold": 90,
    "highlightBoost": 1.5,
    "enablePaletteReduction": true,
    "paletteReduction": 6.0,
    "hueLockAngle": 10,
    "shadowPoint": 20,
    "colorMode": "color",
    "targetColorsSlider": 4,
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none",
    "maskProfile": "Gray Gamma 1.8"
  }
}
