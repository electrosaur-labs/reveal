{
  "id": "atmospheric-photo",
  "name": "Atmospheric Photo",
  "description": "Subtle tones with gentle contrast for atmospheric and dreamy images",
  "settings": {
    "engineType": "reveal",
    "centroidStrategy": "VOLUMETRIC",
    "lWeight": 1.2,
    "cWeight": 1.0,
    "blackBias": 3.0,
    "substrateMode": "auto",
    "substrateTolerance": 4.5,
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.1,
    "highlightThreshold": 95,
    "highlightBoost": 1.2,
    "enablePaletteReduction": true,
    "paletteReduction": 9.0,
    "hueLockAngle": 15,
    "shadowPoint": 10,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": false,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none"
  }
}