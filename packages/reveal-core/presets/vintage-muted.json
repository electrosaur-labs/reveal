{
  "id": "vintage-muted",
  "name": "Vintage / Muted",
  "description": "Subdued tones with balanced approach for vintage and muted images",
  "settings": {
    "engineType": "balanced",
    "centroidStrategy": "VOLUMETRIC",
    "lWeight": 0.8,
    "cWeight": 1.0,
    "blackBias": 2.0,
    "substrateMode": "auto",
    "substrateTolerance": 4.0,
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.0,
    "highlightThreshold": 90,
    "highlightBoost": 1.1,
    "enablePaletteReduction": true,
    "paletteReduction": 10.0,
    "hueLockAngle": 18,
    "shadowPoint": 12,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": false,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none"
  }
}
