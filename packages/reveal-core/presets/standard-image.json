{
  "id": "standard-image",
  "name": "Standard Default",
  "description": "Balanced settings for typical photos",
  "settings": {
    "engineType": "reveal",
    "centroidStrategy": "VOLUMETRIC",
    "lWeight": 1.0,
    "cWeight": 1.0,
    "blackBias": 5.0,
    "substrateMode": "auto",
    "substrateTolerance": 3.5,
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.0,
    "highlightThreshold": 95,
    "highlightBoost": 1.5,
    "enablePaletteReduction": true,
    "paletteReduction": 8.0,
    "hueLockAngle": 15,
    "shadowPoint": 15,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": false,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none"
  }
}
