{
  "id": "deep-shadow-noir",
  "name": "Deep Shadow / Noir",
  "description": "Rich shadows and dramatic contrast for noir and moody images",
  "settings": {
    "engineType": "reveal",
    "centroidStrategy": "SALIENCY",
    "blackBias": 8.0,
    "lWeight": 1.5,
    "cWeight": 1.2,
    "paletteReduction": 7.5,
    "hueLockAngle": 12,
    "shadowPoint": 5,
    "highlightThreshold": 80
  }
}
