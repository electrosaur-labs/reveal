{
  "id": "punchy-commercial",
  "name": "Punchy / Commercial",
  "description": "Data-driven preset for commercial photography with high contrast and saturation",
  "settings": {
    "engineType": "reveal",
    "centroidStrategy": "SALIENCY",
    "lWeight": 1.0,
    "cWeight": 1.5,
    "blackBias": 4.0,
    "substrateMode": "auto",
    "substrateTolerance": 2.0,
    "vibrancyMode": "moderate",
    "vibrancyBoost": 1.1,
    "highlightThreshold": 90,
    "highlightBoost": 1.3,
    "enablePaletteReduction": true,
    "paletteReduction": 12.0,
    "hueLockAngle": 25,
    "shadowPoint": 15,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "Atkinson",
    "maskProfile": "Gray Gamma 2.2"
  }
}
