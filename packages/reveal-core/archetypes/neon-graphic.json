{
  "id": "neon_graphic",
  "name": "Neon / Fluorescent Graphic",
  "description": "Aggressive hue-locking for ultra-saturated flat art. Prevents bleed between vibrant spot colors.",
  "centroid": {
    "l": 60,
    "c": 90,
    "k": 50,
    "l_std_dev": 4
  },
  "weights": {
    "l": 0.5,
    "c": 2.0,
    "k": 1.0,
    "l_std_dev": 4.0
  },
  "parameters": {
    "targetColorsSlider": 6,
    "ditherType": "none",
    "distanceMetric": "cie76",
    "lWeight": 0.5,
    "cWeight": 6.5,
    "blackBias": 1.0,
    "vibrancyMode": "exponential",
    "vibrancyBoost": 1.8,
    "vibrancyThreshold": 0,
    "highlightThreshold": 98,
    "highlightBoost": 1.0,
    "enablePaletteReduction": true,
    "paletteReduction": 3.0,
    "substrateMode": "auto",
    "substrateTolerance": 1.5,
    "shadowPoint": 2,
    "enableHueGapAnalysis": true,
    "hueLockAngle": 45,
    "colorMode": "color",
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "maskProfile": "Gray Gamma 2.2",
    "neutralSovereigntyThreshold": 20,
    "neutralCentroidClampThreshold": 15.0,
    "preprocessingIntensity": "none"
  }
}
