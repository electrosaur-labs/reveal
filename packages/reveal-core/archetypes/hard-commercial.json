{
  "id": "hard_commercial",
  "name": "Punchy / Commercial",
  "description": "Standard brightness, high contrast, saturated (advertising)",
  "centroid": {
    "l": 50,
    "c": 30,
    "k": 75,
    "l_std_dev": 20
  },
  "weights": {
    "l": 0.5,
    "c": 1.0,
    "k": 2.0,
    "l_std_dev": 1.0
  },
  "parameters": {
    "engineType": "reveal",
    "centroidStrategy": "SALIENCY",
    "lWeight": 1.0,
    "cWeight": 1.5,
    "blackBias": 4.0,
    "substrateMode": "auto",
    "substrateTolerance": 2.0,
    "vibrancyMode": "moderate",
    "vibrancyBoost": 1.1,
    "vibrancyThreshold": 5,
    "highlightThreshold": 90,
    "highlightBoost": 1.3,
    "enablePaletteReduction": true,
    "paletteReduction": 6.0,
    "hueLockAngle": 25,
    "shadowPoint": 15,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "Atkinson",
    "maskProfile": "Gray Gamma 2.2"
  },
  "dna_scales": [
    {
      "name": "Scale cWeight by chroma intensity",
      "param": "cWeight",
      "by": "c",
      "inputRange": [20, 50],
      "outputRange": [1.5, 3.0],
      "clamp": true
    }
  ],
  "dna_constraints": [
    {
      "name": "Extreme Contrast Punch",
      "priority": 100,
      "if": "k > 80",
      "then": {
        "blackBias": 5.5,
        "lWeight": 1.3,
        "paletteReduction": 5.0
      }
    },
    {
      "name": "Chroma Boost (Saturated Commercial)",
      "priority": 95,
      "if": "maxC > 80",
      "then": {
        "centroidStrategy": "SALIENCY",
        "cWeight": 2.5,
        "vibrancyMode": "moderate",
        "vibrancyBoost": 1.3
      }
    },
    {
      "name": "Shadow Deepening",
      "priority": 85,
      "if": "minL < 10",
      "then": {
        "shadowPoint": 10,
        "blackBias": 6.0
      }
    },
    {
      "name": "Highlight Punch",
      "priority": 90,
      "if": "maxL > 93",
      "then": {
        "highlightThreshold": 91,
        "highlightBoost": 1.6
      }
    },
    {
      "name": "Complex Gradation",
      "priority": 75,
      "if": "l_std_dev > 18",
      "then": {
        "ditherType": "BlueNoise"
      }
    }
  ]
}
