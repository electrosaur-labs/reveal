{
  "id": "pastel_high_key",
  "name": "Pastel / High-Key",
  "description": "Very bright, soft colors, low contrast",
  "centroid": {
    "l": 85,
    "c": 20,
    "k": 30,
    "l_std_dev": 15
  },
  "weights": {
    "l": 1.0,
    "c": 1.0,
    "k": 0.5,
    "l_std_dev": 1.5
  },
  "parameters": {
    "engineType": "reveal",
    "centroidStrategy": "SALIENCY",
    "lWeight": 1.0,
    "cWeight": 1.8,
    "blackBias": 0.0,
    "substrateMode": "white",
    "substrateTolerance": 5.0,
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.1,
    "vibrancyThreshold": 20,
    "highlightThreshold": 94,
    "highlightBoost": 1.4,
    "enablePaletteReduction": true,
    "paletteReduction": 6.0,
    "hueLockAngle": 12,
    "shadowPoint": 20,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": true,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none",
    "maskProfile": "Gray Gamma 2.2"
  },
  "dna_scales": [
    {
      "name": "Scale highlight threshold by brightness",
      "param": "highlightThreshold",
      "by": "maxL",
      "inputRange": [90, 100],
      "outputRange": [94, 98],
      "clamp": true
    }
  ],
  "dna_constraints": [
    {
      "name": "Extreme Highlight Protection (Near-White)",
      "priority": 100,
      "if": "maxL > 97",
      "then": {
        "highlightThreshold": 98,
        "substrateTolerance": 6.0,
        "preserveWhite": true
      }
    },
    {
      "name": "Soft Gradients (Enable Dithering)",
      "priority": 80,
      "if": "l_std_dev > 12",
      "then": {
        "ditherType": "BlueNoise",
        "lWeight": 1.2
      }
    },
    {
      "name": "Muted Pastel Enhancement",
      "priority": 85,
      "if": "c < 25",
      "then": {
        "vibrancyMode": "exponential",
        "vibrancyBoost": 1.3,
        "cWeight": 2.0
      }
    },
    {
      "name": "Very Low Contrast Adjustment",
      "priority": 70,
      "if": "k < 40",
      "then": {
        "blackBias": 0.0,
        "shadowPoint": 25,
        "paletteReduction": 8.0
      }
    }
  ]
}
