{
  "id": "pure_graphic",
  "name": "Pure Graphic / Vector",
  "description": "Ultra-flat colors, zero gradients, solid shapes (logos, flat vector art)",
  "centroid": {
    "l": 50,
    "c": 40,
    "k": 60,
    "l_std_dev": 2.5
  },
  "weights": {
    "l": 0.5,
    "c": 1.0,
    "k": 1.0,
    "l_std_dev": 5.0
  },
  "parameters": {
    "engineType": "balanced",
    "centroidStrategy": "VOLUMETRIC",
    "lWeight": 0.5,
    "cWeight": 1.5,
    "blackBias": 1.0,
    "substrateMode": "auto",
    "substrateTolerance": 1.5,
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.0,
    "vibrancyThreshold": 0,
    "highlightThreshold": 98,
    "highlightBoost": 1.0,
    "enablePaletteReduction": true,
    "paletteReduction": 3.0,
    "hueLockAngle": 60,
    "shadowPoint": 2,
    "colorMode": "color",
    "targetColorsSlider": 4,
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": false,
    "ditherType": "none",
    "maskProfile": "Gray Gamma 2.2"
  },
  "dna_constraints": [
    {
      "name": "Minkler Flatten (Entropy-Driven Ultra-Flat Graphics)",
      "priority": 100,
      "if": "l_std_dev < 5",
      "then": {
        "lWeight": 0.0,
        "ditherType": "none",
        "paletteReduction": 3.0,
        "blackBias": 1.0,
        "hueLockAngle": 60
      }
    },
    {
      "name": "Sector Hue Locking (Flat Color Planes)",
      "priority": 95,
      "if": "sectors.any.weight > 0.20 && sectors.any.lStdDev < 5",
      "then": {
        "lWeight": 0.2,
        "hueLockAngle": 75,
        "paletteReduction": 2.0
      }
    },
    {
      "name": "High Chroma Graphic Protection",
      "priority": 90,
      "if": "maxC > 80",
      "then": {
        "centroidStrategy": "SALIENCY",
        "cWeight": 2.0,
        "vibrancyBoost": 1.2
      }
    },
    {
      "name": "Preserve Sharp Edges",
      "priority": 80,
      "if": "k > 70",
      "then": {
        "ditherType": "none",
        "paletteReduction": 2.0
      }
    }
  ]
}
