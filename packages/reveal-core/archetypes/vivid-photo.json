{
  "id": "vivid_photo",
  "version": "2.0.0",
  "name": "Vivid Photo",
  "group": "vibrant",
  "engine": "direct",
  "description": "Finds vibrant details without crushing luminance. Balanced c-weight preserves form while boosting chroma.",
  "centroid": {
    "l": 50,
    "c": 45,
    "k": 95,
    "l_std_dev": 25,
    "hue_entropy": 0.4,
    "temperature_bias": 0,
    "primary_sector_weight": 0.3
  },
  "weights": {
    "l": 0.2,
    "c": 6,
    "k": 1,
    "l_std_dev": 0.5,
    "primary_sector_weight": 2.5
  },
  "parameters": {
    "minColors": 6,
    "maxColors": 12,
    "ditherType": "atkinson",
    "distanceMetric": "cie94",
    "lWeight": "image.dna.global.l_std_dev / 10",
    "cWeight": 4.0,
    "blackBias": 3.0,
    "vibrancyMode": "moderate",
    "vibrancyBoost": 1.15,
    "highlightThreshold": 95,
    "highlightBoost": 1.1,
    "enablePaletteReduction": true,
    "paletteReduction": "channels > 8 ? 4.0 : 3.5",
    "substrateMode": "auto",
    "substrateTolerance": 2.5,
    "shadowPoint": 10,
    "enableHueGapAnalysis": true,
    "hueLockAngle": 15,
    "colorMode": "color",
    "preserveWhite": false,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "neutralSovereigntyThreshold": 10,
    "preprocessingIntensity": "medium",
    "shadowClamp": "Math.max(4, press.mesh / 80)",
    "chromaGate": "image.dna.global.k > 80 ? 1.5 : 1.2",
    "speckleRescue": 4,
    "minVolume": 1,
    "refinementPasses": 1
  }
}
