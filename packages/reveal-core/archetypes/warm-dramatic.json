{
  "id": "warm_dramatic",
  "version": "1.3.0",
  "name": "Warm Dramatic",
  "group": "vibrant",
  "description": "Bright warm scenes with dramatic shadows and concentrated hue. High K, high L-std, warm temperature, low entropy. Painted murals, warm-lit architecture, sunlit folk art against dark backgrounds.",
  "preferred_sectors": [
    "yellow",
    "orange",
    "chartreuse",
    "green"
  ],
  "centroid": {
    "l": 72,
    "c": 22,
    "k": 100,
    "l_std_dev": 30,
    "hue_entropy": 0.40,
    "temperature_bias": 0.70,
    "primary_sector_weight": 0.25
  },
  "weights": {
    "l": 1.5,
    "c": 2,
    "k": 2,
    "l_std_dev": 2,
    "hue_entropy": 3,
    "temperature_bias": 3,
    "primary_sector_weight": 2
  },
  "parameters": {
    "minColors": 4,
    "maxColors": 10,
    "ditherType": "blue-noise",
    "distanceMetric": "cie2000",
    "lWeight": 0.8,
    "cWeight": 3,
    "bWeight": 2,
    "blackBias": 6,
    "vibrancyMode": "subtle",
    "vibrancyBoost": 1.2,
    "vibrancyThreshold": 15,
    "highlightThreshold": 96,
    "highlightBoost": 1.5,
    "enablePaletteReduction": true,
    "paletteReduction": 6,
    "substrateMode": "auto",
    "substrateTolerance": 2,
    "shadowPoint": 8,
    "enableHueGapAnalysis": true,
    "hueLockAngle": 12,
    "colorMode": "color",
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "maskProfile": "Gray Gamma 2.2",
    "neutralSovereigntyThreshold": 0,
    "neutralCentroidClampThreshold": 1,
    "preprocessingIntensity": "light",
    "shadowClamp": 4,
    "speckleRescue": 4,
    "minVolume": 1,
    "refinementPasses": 1,
    "shadowChromaGateL": 45
  }
}
