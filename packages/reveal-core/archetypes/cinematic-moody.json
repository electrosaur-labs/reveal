{
  "id": "cinematic_moody",
  "name": "Cinematic / Moody",
  "description": "Darker tones, moderate saturation, good contrast",
  "centroid": {
    "l": 40,
    "c": 25,
    "k": 65,
    "l_std_dev": 22
  },
  "weights": {
    "l": 1.0,
    "c": 1.0,
    "k": 1.5,
    "l_std_dev": 1.0
  },
  "parameters": {
    "engineType": "reveal",
    "centroidStrategy": "VOLUMETRIC",
    "lWeight": 1.2,
    "cWeight": 1.5,
    "blackBias": 5.0,
    "substrateMode": "auto",
    "substrateTolerance": 2.0,
    "vibrancyMode": "subtle",
    "vibrancyBoost": 0.95,
    "vibrancyThreshold": 10,
    "highlightThreshold": 85,
    "highlightBoost": 1.2,
    "enablePaletteReduction": true,
    "paletteReduction": 6.0,
    "hueLockAngle": 20,
    "shadowPoint": 20,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "BlueNoise",
    "maskProfile": "Gray Gamma 2.2"
  },
  "dna_scales": [
    {
      "name": "Scale blackBias by darkness",
      "param": "blackBias",
      "by": "minL",
      "inputRange": [0, 20],
      "outputRange": [8.0, 5.0],
      "clamp": true
    }
  ],
  "dna_constraints": [
    {
      "name": "Dominant Dark Sector (L-Centroid Driven)",
      "priority": 105,
      "if": "sectors.any.weight > 0.25 && sectors.any.lMean < 40",
      "then": {
        "blackBias": 7.0,
        "shadowPoint": 5,
        "lWeight": 1.6
      }
    },
    {
      "name": "Deep Shadow Protection",
      "priority": 100,
      "if": "minL < 5",
      "then": {
        "shadowPoint": 3,
        "blackBias": 8.0,
        "preserveBlack": true
      }
    },
    {
      "name": "Moderate Contrast Enhancement",
      "priority": 90,
      "if": "k > 70",
      "then": {
        "lWeight": 1.5,
        "paletteReduction": 5.0
      }
    },
    {
      "name": "Moody Color Preservation",
      "priority": 85,
      "if": "c > 20 && c < 40",
      "then": {
        "vibrancyMode": "moderate",
        "vibrancyBoost": 1.1,
        "cWeight": 1.8
      }
    },
    {
      "name": "Dark Texture Smoothing",
      "priority": 80,
      "if": "l < 45",
      "then": {
        "ditherType": "BlueNoise",
        "lWeight": 1.4
      }
    },
    {
      "name": "Soft Neutral Axis Lock",
      "priority": 980,
      "if": "global.neutralWeight > 0.08",
      "then": {
        "hardNeutralLock": true,
        "useNeutralGravity": true,
        "neutralStiffness": 15.0,
        "neutralDeadZone": 2.5,
        "neutralChromaThreshold": 4.0,
        "cWeight": 3.0,
        "description": "Moderate hard-lock allows artistic grading while preventing excessive chatter"
      }
    }
  ]
}
