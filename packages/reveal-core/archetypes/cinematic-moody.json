{
  "id": "cinematic_moody",
  "version": "1.0.0",
  "name": "Cinematic / Moody",
  "description": "Deep tones and heavy shadows. Prevents shadow fusion in low-exposure shots.",
  "preferred_sectors": [
    "blue",
    "cyan",
    "purple"
  ],
  "centroid": {
    "l": 40,
    "c": 25,
    "k": 65,
    "l_std_dev": 22,
    "hue_entropy": 0.55,
    "temperature_bias": -0.2,
    "primary_sector_weight": 0.25
  },
  "weights": {
    "l": 2,
    "c": 1.5,
    "k": 1,
    "l_std_dev": 2,
    "temperature_bias": 1.5
  },
  "parameters": {
    "minColors": 4,
    "maxColors": 10,
    "ditherType": "blue-noise",
    "distanceMetric": "cie2000",
    "lWeight": 1.5,
    "cWeight": 2.5,
    "blackBias": 7,
    "vibrancyMode": "aggressive",
    "vibrancyBoost": 1.3,
    "vibrancyThreshold": 10,
    "highlightThreshold": 85,
    "highlightBoost": 1.2,
    "enablePaletteReduction": true,
    "paletteReduction": 8,
    "substrateMode": "auto",
    "substrateTolerance": 2,
    "shadowPoint": 4,
    "enableHueGapAnalysis": true,
    "hueLockAngle": 20,
    "colorMode": "color",
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "maskProfile": "Gray Gamma 2.2",
    "neutralSovereigntyThreshold": 5,
    "neutralCentroidClampThreshold": 1.2,
    "preprocessingIntensity": "heavy",
    "refinementPasses": 1
  }
}
