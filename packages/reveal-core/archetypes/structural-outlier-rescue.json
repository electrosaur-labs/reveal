{
  "id": "structural_outlier_rescue",
  "version": "1.0.0",
  "name": "Subtle Naturalist / Structural Rescue",
  "description": "Surgical recovery for monochromatic, high-detail images. Prevents saliency shadow.",
  "centroid": {
    "l": 60,
    "c": 11,
    "k": 100,
    "l_std_dev": 26,
    "hue_entropy": 0.25,
    "temperature_bias": 0,
    "primary_sector_weight": 0.6
  },
  "weights": {
    "l": 1,
    "c": 3,
    "k": 1.5,
    "l_std_dev": 1.5,
    "hue_entropy": 3
  },
  "parameters": {
    "targetColorsSlider": 8,
    "ditherType": "atkinson",
    "distanceMetric": "cie2000",
    "lWeight": 2,
    "cWeight": 4.5,
    "blackBias": 8,
    "vibrancyMode": "subtle",
    "vibrancyBoost": 1.05,
    "vibrancyThreshold": 18,
    "highlightThreshold": 97,
    "highlightBoost": 2,
    "enablePaletteReduction": true,
    "paletteReduction": 6,
    "substrateMode": "auto",
    "substrateTolerance": 1,
    "shadowPoint": 8,
    "enableHueGapAnalysis": true,
    "hueLockAngle": 15,
    "colorMode": "color",
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "maskProfile": "Gray Gamma 2.2",
    "neutralSovereigntyThreshold": 0,
    "neutralCentroidClampThreshold": 0.2,
    "preprocessingIntensity": "light",
    "shadowClamp": 6,
    "speckleRescue": 4,
    "minVolume": 1,
    "refinementPasses": 1
  }
}
