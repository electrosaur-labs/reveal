{
  "id": "soft_ethereal",
  "name": "Soft / Ethereal",
  "description": "Maintains hazy mid-tones and prevents harsh edge artifacts in low-contrast, high-key photography.",
  "centroid": {
    "l": 75,
    "c": 15,
    "k": 40,
    "l_std_dev": 12
  },
  "weights": {
    "l": 1.0,
    "c": 1.0,
    "k": 0.5,
    "l_std_dev": 1.5
  },
  "parameters": {
    "targetColorsSlider": 8,
    "ditherType": "blue-noise",
    "distanceMetric": "cie94",
    "lWeight": 1.2,
    "cWeight": 1.2,
    "blackBias": 2.0,
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.0,
    "vibrancyThreshold": 15,
    "highlightThreshold": 94,
    "highlightBoost": 1.1,
    "enablePaletteReduction": true,
    "paletteReduction": 9.0,
    "substrateMode": "white",
    "substrateTolerance": 4.5,
    "shadowPoint": 20,
    "enableHueGapAnalysis": true,
    "hueLockAngle": 15,
    "colorMode": "color",
    "preserveWhite": true,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "maskProfile": "Gray Gamma 2.2",
    "neutralSovereigntyThreshold": 5,
    "neutralCentroidClampThreshold": 1.5,
    "preprocessingIntensity": "light"
  }
}
