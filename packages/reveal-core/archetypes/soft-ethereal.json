{
  "id": "soft_ethereal",
  "name": "Soft / Ethereal",
  "description": "Mid-bright, low contrast, soft (dreamy photos)",
  "centroid": {
    "l": 65,
    "c": 20,
    "k": 40,
    "l_std_dev": 18
  },
  "weights": {
    "l": 0.5,
    "c": 1.0,
    "k": 0.5,
    "l_std_dev": 1.0
  },
  "parameters": {
    "engineType": "reveal",
    "centroidStrategy": "VOLUMETRIC",
    "lWeight": 1.0,
    "cWeight": 1.5,
    "blackBias": 3.0,
    "substrateMode": "auto",
    "substrateTolerance": 4.5,
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.1,
    "vibrancyThreshold": 15,
    "highlightThreshold": 95,
    "highlightBoost": 1.2,
    "enablePaletteReduction": true,
    "paletteReduction": 6.0,
    "hueLockAngle": 15,
    "shadowPoint": 10,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": false,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none",
    "maskProfile": "Gray Gamma 2.2"
  },
  "dna_constraints": [
    {
      "name": "Enable Dithering for Tonal Complexity",
      "priority": 80,
      "if": "l_std_dev > 15",
      "then": {
        "ditherType": "BlueNoise",
        "lWeight": 1.2
      }
    },
    {
      "name": "Highlight Protection (Dreamy Whites)",
      "priority": 90,
      "if": "maxL > 95",
      "then": {
        "highlightThreshold": 96,
        "highlightBoost": 1.5,
        "substrateTolerance": 5.0
      }
    },
    {
      "name": "Low Contrast Softness",
      "priority": 70,
      "if": "k < 50",
      "then": {
        "blackBias": 2.0,
        "paletteReduction": 8.0
      }
    },
    {
      "name": "Muted Color Enhancement",
      "priority": 75,
      "if": "c < 25",
      "then": {
        "vibrancyMode": "exponential",
        "vibrancyBoost": 1.3
      }
    },
    {
      "name": "Cool-to-Neutral Protection",
      "priority": 950,
      "if": "sectors.blue.weight > 0.15 && global.neutralWeight > 0.10",
      "then": {
        "cWeight": 3.5,
        "useNeutralAnchoring": true,
        "neutralStiffness": 15.0,
        "description": "Increases chroma weighting and enables neutral anchoring to prevent blue bleeding into gray midtones"
      }
    }
  ]
}
