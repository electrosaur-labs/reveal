{
  "id": "soft_ethereal",
  "name": "Soft / Ethereal",
  "description": "Mid-bright, low contrast, soft (dreamy photos)",
  "centroid": {
    "l": 65,
    "c": 20,
    "k": 40,
    "l_std_dev": 18
  },
  "weights": {
    "l": 0.5,
    "c": 1.0,
    "k": 0.5,
    "l_std_dev": 1.0
  },
  "parameters": {
    "engineType": "reveal",
    "centroidStrategy": "VOLUMETRIC",
    "lWeight": 1.0,
    "cWeight": 1.5,
    "blackBias": 3.0,
    "substrateMode": "auto",
    "substrateTolerance": 4.5,
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.1,
    "vibrancyThreshold": 15,
    "highlightThreshold": 95,
    "highlightBoost": 1.2,
    "enablePaletteReduction": true,
    "paletteReduction": 6.0,
    "hueLockAngle": 15,
    "shadowPoint": 10,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": false,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none",
    "maskProfile": "Gray Gamma 2.2"
  },
  "dna_constraints": [
    {
      "name": "Enable Dithering for Tonal Complexity",
      "priority": 80,
      "if": "l_std_dev > 15",
      "then": {
        "ditherType": "BlueNoise",
        "lWeight": 1.2
      }
    },
    {
      "name": "Highlight Protection (Dreamy Whites)",
      "priority": 90,
      "if": "maxL > 95",
      "then": {
        "highlightThreshold": 96,
        "highlightBoost": 1.5,
        "substrateTolerance": 5.0
      }
    },
    {
      "name": "Low Contrast Softness",
      "priority": 70,
      "if": "k < 50",
      "then": {
        "blackBias": 2.0,
        "paletteReduction": 8.0
      }
    },
    {
      "name": "Muted Color Enhancement",
      "priority": 75,
      "if": "c < 25",
      "then": {
        "vibrancyMode": "exponential",
        "vibrancyBoost": 1.3
      }
    },
    {
      "name": "THERMONUCLEAR: Achromatic Axis Lock",
      "priority": 1000,
      "if": "global.neutralWeight > 0.10 && global.chromaticCoverage > 0.30",
      "then": {
        "useAchromaticProjection": true,
        "hardNeutralLock": true,
        "neutralSovereigntyThreshold": 18.0,
        "neutralCentroidClampThreshold": 18.0,
        "lWeight": 40.0,
        "cWeight": 0.0,
        "blackBias": 6.0,
        "description": "Wide-Gate Isolation: Forces ALL low-saturation pixels (chroma < 18.0) to use L-only distance with 40.0× lightness weighting, preventing 'ghost swatches' like desaturated blue-pink grays from attracting fur pixels. Centroid clamping snaps weak-chroma clusters to pure gray."
      }
    },
    {
      "name": "Neutral Axis Hard-Lock (Fallback)",
      "priority": 990,
      "if": "global.neutralWeight > 0.05",
      "then": {
        "hardNeutralLock": true,
        "useNeutralGravity": true,
        "neutralStiffness": 35.0,
        "neutralDeadZone": 3.0,
        "neutralChromaThreshold": 3.5,
        "cWeight": 4.0,
        "description": "Hard-locks neutral centroids to a=0,b=0 and creates dead-zone to prevent pink/blue chatter"
      }
    }
  ]
}
