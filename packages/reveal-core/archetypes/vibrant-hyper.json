{
  "id": "vibrant_hyper",
  "version": "1.0.0",
  "name": "Vibrant / Graphic",
  "description": "Maximizes chroma over tonal precision. Ideal for pop art and bright concert posters.",
  "centroid": {
    "l": 50,
    "c": 60,
    "k": 70,
    "l_std_dev": 25,
    "hue_entropy": 0.4,
    "temperature_bias": 0,
    "primary_sector_weight": 0.35
  },
  "weights": {
    "l": 0.5,
    "c": 1.5,
    "k": 1,
    "l_std_dev": 2
  },
  "parameters": {
    "minColors": 6,
    "maxColors": 12,
    "ditherType": "none",
    "distanceMetric": "cie76",
    "lWeight": 0.8,
    "cWeight": 4.5,
    "blackBias": 2,
    "vibrancyMode": "aggressive",
    "vibrancyBoost": 1.6,
    "vibrancyThreshold": 0,
    "highlightThreshold": 95,
    "highlightBoost": 1,
    "enablePaletteReduction": true,
    "paletteReduction": 12,
    "substrateMode": "auto",
    "substrateTolerance": 2,
    "shadowPoint": 5,
    "enableHueGapAnalysis": true,
    "hueLockAngle": 30,
    "colorMode": "color",
    "preserveWhite": false,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "maskProfile": "Gray Gamma 2.2",
    "neutralSovereigntyThreshold": 18,
    "neutralCentroidClampThreshold": 10,
    "preprocessingIntensity": "none",
    "refinementPasses": 1
  }
}
