{
  "id": "painterly",
  "version": "2.0.0",
  "name": "Painterly",
  "group": "natural",
  "engine": "direct",
  "description": "Warm-toned painterly scenes with high hue diversity. Complex multi-hue compositions where many sectors contribute — landscapes, genre scenes, Art Nouveau illustrations. Higher entropy than Warm Dramatic; warmer than Subtle Naturalist.",
  "preferred_sectors": [
    "yellow",
    "orange",
    "chartreuse",
    "green",
    "cyan",
    "red"
  ],
  "centroid": {
    "l": 65,
    "c": 17,
    "k": 90,
    "l_std_dev": 20,
    "hue_entropy": 0.62,
    "temperature_bias": 0.55,
    "primary_sector_weight": 0.4
  },
  "weights": {
    "l": 1,
    "c": 1,
    "k": 1,
    "l_std_dev": 1,
    "hue_entropy": 3,
    "temperature_bias": 0.5,
    "primary_sector_weight": 2.5
  },
  "parameters": {
    "minColors": 5,
    "maxColors": 10,
    "ditherType": "atkinson",
    "distanceMetric": "cie2000",
    "lWeight": 1.2,
    "cWeight": "2.5 + (image.dna.global.hue_entropy * 2)",
    "blackBias": 6,
    "vibrancyMode": "moderate",
    "vibrancyBoost": 1.3,
    "highlightThreshold": 95,
    "highlightBoost": "image.dna.global.temperature_bias > 0.5 ? 1.5 : 1.3",
    "enablePaletteReduction": true,
    "paletteReduction": 6,
    "substrateMode": "auto",
    "substrateTolerance": 2,
    "shadowPoint": 10,
    "enableHueGapAnalysis": true,
    "hueLockAngle": 15,
    "colorMode": "color",
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "neutralSovereigntyThreshold": 0,
    "preprocessingIntensity": "light",
    "shadowClamp": "Math.max(4, press.mesh / 75)",
    "speckleRescue": 4,
    "minVolume": 1,
    "refinementPasses": "image.dna.global.hue_entropy > 0.7 ? 2 : 1"
  },
  "scoring": {
    "chromaProfile": "moderate",
    "tonalRange": "mid-bright",
    "expects_diversity": true
  }
}
