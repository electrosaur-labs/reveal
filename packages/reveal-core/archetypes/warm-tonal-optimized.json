{
  "id": "warm_tonal_optimized",
  "name": "Warm Tonal / Yellow Protect",
  "description": "Optimized for photographic images where yellows must remain sovereign from browns and earthy tones.",
  "centroid": {
    "l": 55,
    "c": 35,
    "k": 70,
    "l_std_dev": 22
  },
  "weights": {
    "l": 0.2,
    "c": 4.5,
    "k": 1.0,
    "l_std_dev": 1.5
  },
  "parameters": {
    "engineType": "reveal",
    "centroidStrategy": "SALIENCY",
    "lWeight": 0.3,
    "cWeight": 5.0,
    "blackBias": 4.0,
    "substrateMode": "auto",
    "substrateTolerance": 3.0,
    "vibrancyMode": "exponential",
    "vibrancyBoost": 1.8,
    "vibrancyThreshold": 8.0,
    "highlightThreshold": 96,
    "highlightBoost": 1.6,
    "enablePaletteReduction": true,
    "paletteReduction": 4.0,
    "hueLockAngle": 45,
    "shadowPoint": 12,
    "colorMode": "color",
    "targetColorsSlider": 10,
    "preserveWhite": true,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "BlueNoise",
    "maskProfile": "Gray Gamma 2.2"
  },
  "dna_scales": [
    {
      "name": "Scale lWeight for yellow/orange separation",
      "param": "lWeight",
      "by": "yellowDominance",
      "inputRange": [10, 30],
      "outputRange": [0.3, 2.5],
      "clamp": true
    }
  ],
  "dna_constraints": [
    {
      "name": "Yellow Protection (Warm Photos)",
      "priority": 100,
      "if": "yellowDominance > 10 || (maxC > 70 && maxCHue >= 60 && maxCHue <= 100)",
      "then": {
        "centroidStrategy": "SALIENCY",
        "lWeight": 2.5,
        "hueLockAngle": 50,
        "vibrancyBoost": 1.8
      }
    },
    {
      "name": "Warmth Preservation (Orange/Red)",
      "priority": 95,
      "if": "maxCHue >= 0 && maxCHue <= 60",
      "then": {
        "hueLockAngle": 45,
        "cWeight": 5.5,
        "paletteReduction": 3.5
      }
    },
    {
      "name": "High Contrast Warm Tones",
      "priority": 85,
      "if": "k > 75",
      "then": {
        "blackBias": 5.0,
        "shadowPoint": 10
      }
    },
    {
      "name": "Complex Tonal Gradients",
      "priority": 80,
      "if": "l_std_dev > 20",
      "then": {
        "ditherType": "BlueNoise",
        "lWeight": 1.0
      }
    }
  ]
}
