{
  "id": "pastel",
  "version": "2.0.0",
  "name": "Pastel",
  "group": "soft",
  "engine": "direct",
  "description": "Very bright, soft colors. Protects gradients in high-key photography.",
  "centroid": {
    "l": 85,
    "c": 20,
    "k": 30,
    "l_std_dev": 15,
    "hue_entropy": 0.6,
    "temperature_bias": 0.1,
    "primary_sector_weight": 0.2
  },
  "weights": {
    "l": 3,
    "c": 1,
    "k": 0.5,
    "l_std_dev": 1.5,
    "hue_entropy": 1
  },
  "parameters": {
    "minColors": 4,
    "maxColors": 8,
    "ditherType": "none",
    "distanceMetric": "cie94",
    "lWeight": 1,
    "cWeight": "1.8 + (image.dna.global.primary_sector_weight * 0.5)",
    "blackBias": 0,
    "substrateMode": "white",
    "substrateTolerance": "image.dna.global.l / 15",
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.1,
    "highlightThreshold": "image.dna.global.l_std_dev > 20 ? 92 : 94",
    "highlightBoost": 1.4,
    "enablePaletteReduction": true,
    "paletteReduction": 6,
    "hueLockAngle": 12,
    "shadowPoint": "image.dna.global.l > 80 ? 25 : 20",
    "colorMode": "color",
    "preserveWhite": true,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "neutralSovereigntyThreshold": 5,
    "preprocessingIntensity": "light",
    "refinementPasses": 1
  }
}
