{
  "id": "minkler",
  "version": "2.0.0",
  "name": "Minkler",
  "group": "graphic",
  "engine": "direct",
  "description": "High-contrast graphic posterization with bold blocks of color. Named for Doug Minkler.",
  "preferred_sectors": [
    "chartreuse",
    "orange",
    "yellow",
    "green",
    "red"
  ],
  "centroid": {
    "l": 69,
    "c": 18,
    "k": 99,
    "l_std_dev": 35,
    "hue_entropy": 0.65,
    "temperature_bias": 0.2,
    "primary_sector_weight": 0.38
  },
  "weights": {
    "l": 1,
    "c": 1,
    "k": 5,
    "l_std_dev": 5,
    "hue_entropy": 2,
    "temperature_bias": 1.5,
    "primary_sector_weight": 2
  },
  "parameters": {
    "minColors": 5,
    "maxColors": 10,
    "ditherType": "none",
    "distanceMetric": "cie76",
    "lWeight": 1,
    "cWeight": 2,
    "blackBias": "image.dna.global.k > 90 ? 8 : 7",
    "vibrancyMode": "moderate",
    "vibrancyBoost": "image.dna.global.hue_entropy > 0.5 ? 1.4 : 1.3",
    "highlightThreshold": 95,
    "highlightBoost": 1.2,
    "enablePaletteReduction": true,
    "paletteReduction": 6,
    "substrateMode": "auto",
    "substrateTolerance": 2,
    "shadowPoint": 8,
    "enableHueGapAnalysis": true,
    "hueLockAngle": 20,
    "colorMode": "color",
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "neutralSovereigntyThreshold": 5,
    "preprocessingIntensity": "none",
    "shadowClamp": "Math.max(4, press.mesh / 60)",
    "speckleRescue": "image.dna.global.l_std_dev > 30 ? 6 : 4",
    "minVolume": 1,
    "refinementPasses": 0
  },
  "scoring": {
    "chromaProfile": "low",
    "tonalRange": "mid-bright",
    "expects_warm": true,
    "expects_dominance": true
  }
}
