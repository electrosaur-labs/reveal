{
  "id": "detail_recovery",
  "version": "2.0.0",
  "name": "Detail Recovery",
  "group": "specialist",
  "engine": "direct",
  "description": "Surgical recovery for monochromatic, high-detail images. Prevents saliency shadow.",
  "centroid": {
    "l": 60,
    "c": 11,
    "k": 100,
    "l_std_dev": 26,
    "hue_entropy": 0.25,
    "temperature_bias": 0,
    "primary_sector_weight": 0.6
  },
  "weights": {
    "l": 1,
    "c": 3,
    "k": 1.5,
    "l_std_dev": 1.5,
    "hue_entropy": 3
  },
  "parameters": {
    "minColors": 4,
    "maxColors": 10,
    "ditherType": "atkinson",
    "distanceMetric": "cie2000",
    "lWeight": "Math.max(1.5, 3.0 - (image.dna.global.l / 40))",
    "cWeight": "4.0 + (image.dna.global.primary_sector_weight * 2)",
    "blackBias": 8,
    "vibrancyMode": "subtle",
    "vibrancyBoost": 1.05,
    "highlightThreshold": 97,
    "highlightBoost": "image.dna.global.l_std_dev > 20 ? 2.2 : 2.0",
    "enablePaletteReduction": true,
    "paletteReduction": 6,
    "substrateMode": "auto",
    "substrateTolerance": 1,
    "shadowPoint": 8,
    "enableHueGapAnalysis": true,
    "hueLockAngle": 15,
    "colorMode": "color",
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "neutralSovereigntyThreshold": 0,
    "preprocessingIntensity": "light",
    "shadowClamp": "Math.max(6, press.mesh / 45)",
    "speckleRescue": 4,
    "minVolume": 1,
    "refinementPasses": 1
  },
  "scoring": {
    "chromaProfile": "very_low",
    "tonalRange": "mid-bright",
    "expects_monochrome": true,
    "rewards_high_texture": true
  }
}
