{
  "id": "chromatic_polyphony",
  "version": "1.0.0",
  "name": "Chromatic Polyphony",
  "group": "natural",
  "engine": "direct",
  "description": "High-entropy images with color spread across many sectors. No dominant hue — treats all colors with equal structural respect. Balanced weights prevent any single channel from hijacking separation.",
  "preferred_sectors": [],
  "centroid": {
    "l": 50,
    "c": 34,
    "k": 98,
    "l_std_dev": 26,
    "hue_entropy": 0.9,
    "temperature_bias": 0.32,
    "primary_sector_weight": 0.2
  },
  "weights": {
    "l": 1,
    "c": 1,
    "k": 1,
    "l_std_dev": 2,
    "hue_entropy": 8,
    "temperature_bias": 0.5,
    "primary_sector_weight": 5
  },
  "parameters": {
    "minColors": 10,
    "maxColors": 12,
    "ditherType": "blue-noise",
    "distanceMetric": "cie94",
    "lWeight": 1.5,
    "cWeight": 1.5,
    "blackBias": 3,
    "vibrancyMode": "moderate",
    "vibrancyBoost": 1.2,
    "highlightThreshold": 90,
    "highlightBoost": 1.2,
    "enablePaletteReduction": true,
    "paletteReduction": 6,
    "substrateMode": "auto",
    "substrateTolerance": 2,
    "shadowPoint": 12,
    "enableHueGapAnalysis": true,
    "hueLockAngle": 15,
    "colorMode": "color",
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "neutralSovereigntyThreshold": 0,
    "neutralCentroidClampThreshold": 0.5,
    "preprocessingIntensity": "light",
    "shadowClamp": 4,
    "speckleRescue": 4,
    "medianPass": false,
    "minVolume": 1,
    "refinementPasses": 2
  }
}
