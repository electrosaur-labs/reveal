{
  "id": "neon",
  "version": "2.0.0",
  "name": "Neon",
  "group": "graphic",
  "engine": "direct",
  "description": "Aggressive hue-locking for saturated flat art. Prevents bleed between vibrant spot colors.",
  "preferred_sectors": [
    "yellow",
    "orange",
    "red",
    "magenta"
  ],
  "centroid": {
    "l": 60,
    "c": 90,
    "k": 50,
    "l_std_dev": 4,
    "hue_entropy": 0.5,
    "temperature_bias": 0,
    "primary_sector_weight": 0.4
  },
  "weights": {
    "l": 0.5,
    "c": 2,
    "k": 1,
    "l_std_dev": 4,
    "primary_sector_weight": 3
  },
  "parameters": {
    "minColors": 6,
    "maxColors": 12,
    "ditherType": "none",
    "distanceMetric": "cie76",
    "lWeight": 0.5,
    "cWeight": "6.0 + image.dna.global.hue_entropy",
    "blackBias": 1,
    "vibrancyMode": "exponential",
    "vibrancyBoost": "1.5 + (image.dna.global.primary_sector_weight * 0.5)",
    "highlightThreshold": 98,
    "highlightBoost": 1,
    "enablePaletteReduction": true,
    "paletteReduction": 6.5,
    "substrateMode": "auto",
    "substrateTolerance": 1.5,
    "shadowPoint": 2,
    "enableHueGapAnalysis": true,
    "hueLockAngle": 60,
    "colorMode": "color",
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "neutralSovereigntyThreshold": "image.dna.global.hue_entropy < 0.3 ? 30 : 25",
    "preprocessingIntensity": "none",
    "chromaGate": 1.8,
    "detailRescue": 8,
    "speckleRescue": 4,
    "shadowClamp": "Math.max(4.0, press.mesh / 50)",
    "minVolume": 0.5,
    "refinementPasses": 0
  },
  "scoring": {
    "chromaProfile": "extreme",
    "tonalRange": "bright",
    "expects_flat": true
  }
}
