{
  "id": "bright_desaturated",
  "name": "Bright Desaturated / High-Key Contrast",
  "description": "Bright, washed-out photographic images with extreme contrast and minimal color (overexposed look, bleached aesthetics)",
  "centroid": {
    "l": 75,
    "c": 12,
    "k": 95,
    "l_std_dev": 24
  },
  "weights": {
    "l": 1.0,
    "c": 2.0,
    "k": 2.5,
    "l_std_dev": 1.0
  },
  "parameters": {
    "engineType": "reveal",
    "centroidStrategy": "SALIENCY",
    "lWeight": 1.2,
    "cWeight": 0.8,
    "blackBias": 3.0,
    "substrateMode": "white",
    "substrateTolerance": 4.0,
    "vibrancyMode": "subtle",
    "vibrancyBoost": 0.9,
    "vibrancyThreshold": 20,
    "highlightThreshold": 92,
    "highlightBoost": 1.8,
    "enablePaletteReduction": true,
    "paletteReduction": 7.0,
    "hueLockAngle": 20,
    "shadowPoint": 8,
    "colorMode": "color",
    "targetColorsSlider": 7,
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none",
    "maskProfile": "Gray Gamma 2.2"
  },
  "dna_constraints": [
    {
      "name": "THERMONUCLEAR: Achromatic Axis Lock",
      "priority": 1000,
      "if": "global.neutralWeight > 0.10 && global.chromaticCoverage > 0.30",
      "then": {
        "useAchromaticProjection": true,
        "hardNeutralLock": true,
        "neutralSovereigntyThreshold": 12.0,
        "neutralCentroidClampThreshold": 12.0,
        "lWeight": 15.0,
        "cWeight": 0.0,
        "blackBias": 6.0,
        "description": "Wide-Gate Isolation: Forces ALL low-saturation pixels (chroma < 12.0) to use L-only distance, preventing 'ghost swatches' like desaturated blue-pink grays from attracting fur pixels. Centroid clamping snaps weak-chroma clusters to pure gray."
      }
    },
    {
      "name": "Neutral Axis Hard-Lock (Fallback)",
      "priority": 990,
      "if": "global.neutralWeight > 0.05",
      "then": {
        "hardNeutralLock": true,
        "useNeutralGravity": true,
        "neutralStiffness": 35.0,
        "neutralDeadZone": 3.0,
        "neutralChromaThreshold": 3.5,
        "cWeight": 4.0,
        "description": "Hard-locks neutral centroids to a=0,b=0 and creates dead-zone to prevent pink/blue chatter"
      }
    },
    {
      "name": "Extreme Desaturation Floor",
      "priority": 100,
      "if": "c < 15 && maxC < 80",
      "then": {
        "vibrancyBoost": 0.8,
        "vibrancyThreshold": 25,
        "cWeight": 0.5
      }
    },
    {
      "name": "Extreme Contrast Boost (Bleached Look)",
      "priority": 90,
      "if": "k > 90",
      "then": {
        "blackBias": 4.5,
        "shadowPoint": 5,
        "highlightThreshold": 94
      }
    },
    {
      "name": "Washed Highlight Protection",
      "priority": 85,
      "if": "maxL > 96",
      "then": {
        "highlightThreshold": 95,
        "substrateTolerance": 5.0
      }
    },
    {
      "name": "Enable Dithering for Texture",
      "priority": 75,
      "if": "l_std_dev > 20",
      "then": {
        "ditherType": "BlueNoise",
        "lWeight": 1.4
      }
    }
  ]
}
