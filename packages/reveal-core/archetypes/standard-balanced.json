{
  "id": "standard_balanced",
  "name": "Standard / Balanced",
  "description": "Dead center - typical photos with balanced properties",
  "centroid": {
    "l": 50,
    "c": 25,
    "k": 60,
    "l_std_dev": 20
  },
  "weights": {
    "l": 0.5,
    "c": 1.0,
    "k": 1.5,
    "l_std_dev": 2.0
  },
  "parameters": {
    "engineType": "reveal",
    "centroidStrategy": "VOLUMETRIC",
    "lWeight": 0.9,
    "cWeight": 1.5,
    "blackBias": 5.0,
    "substrateMode": "auto",
    "substrateTolerance": 3.5,
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.0,
    "vibrancyThreshold": 8,
    "highlightThreshold": 95,
    "highlightBoost": 2.2,
    "enablePaletteReduction": true,
    "paletteReduction": 6.0,
    "hueLockAngle": 15,
    "shadowPoint": 15,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": false,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none",
    "maskProfile": "Gray Gamma 2.2"
  },
  "dna_constraints": [
    {
      "name": "Flatness Override",
      "priority": 50,
      "if": "l_std_dev < 8",
      "then": {
        "ditherType": "none",
        "hueLockAngle": 35
      }
    },
    {
      "name": "Shadow Gate Calibration",
      "priority": 60,
      "if": "minL < 2",
      "then": {
        "shadowPoint": 5
      }
    },
    {
      "name": "Highlight Threshold (White Protection)",
      "priority": 70,
      "if": "maxL > 98",
      "then": {
        "highlightThreshold": 96
      }
    },
    {
      "name": "THERMONUCLEAR: Achromatic Axis Lock",
      "priority": 1000,
      "if": "global.neutralWeight > 0.10 && global.chromaticCoverage > 0.30",
      "then": {
        "useAchromaticProjection": true,
        "hardNeutralLock": true,
        "neutralSovereigntyThreshold": 12.0,
        "neutralCentroidClampThreshold": 12.0,
        "lWeight": 15.0,
        "cWeight": 0.0,
        "blackBias": 6.0,
        "description": "Wide-Gate Isolation: Forces ALL low-saturation pixels (chroma < 12.0) to use L-only distance, preventing 'ghost swatches' like desaturated blue-pink grays from attracting fur pixels. Centroid clamping snaps weak-chroma clusters to pure gray."
      }
    },
    {
      "name": "Neutral Axis Hard-Lock (Fallback)",
      "priority": 990,
      "if": "global.neutralWeight > 0.05",
      "then": {
        "hardNeutralLock": true,
        "useNeutralGravity": true,
        "neutralStiffness": 35.0,
        "neutralDeadZone": 3.0,
        "neutralChromaThreshold": 3.5,
        "cWeight": 4.0,
        "description": "Hard-locks neutral centroids to a=0,b=0 and creates dead-zone to prevent pink/blue chatter"
      }
    }
  ]
}
