{
  "id": "standard_balanced",
  "name": "Standard / Balanced",
  "description": "Dead center - typical photos with balanced properties",
  "centroid": {
    "l": 50,
    "c": 25,
    "k": 60,
    "l_std_dev": 20
  },
  "weights": {
    "l": 0.5,
    "c": 1.0,
    "k": 1.5,
    "l_std_dev": 2.0
  },
  "parameters": {
    "engineType": "reveal",
    "centroidStrategy": "VOLUMETRIC",
    "lWeight": 0.9,
    "cWeight": 1.5,
    "blackBias": 5.0,
    "substrateMode": "auto",
    "substrateTolerance": 3.5,
    "vibrancyMode": "linear",
    "vibrancyBoost": 1.0,
    "vibrancyThreshold": 8,
    "highlightThreshold": 95,
    "highlightBoost": 2.2,
    "enablePaletteReduction": true,
    "paletteReduction": 6.0,
    "hueLockAngle": 15,
    "shadowPoint": 15,
    "colorMode": "color",
    "targetColorsSlider": 8,
    "preserveWhite": false,
    "preserveBlack": false,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": true,
    "ditherType": "none",
    "maskProfile": "Gray Gamma 2.2"
  },
  "dna_constraints": [
    {
      "name": "Flatness Override",
      "priority": 50,
      "if": "l_std_dev < 8",
      "then": {
        "ditherType": "none",
        "hueLockAngle": 35
      }
    },
    {
      "name": "Shadow Gate Calibration",
      "priority": 60,
      "if": "minL < 2",
      "then": {
        "shadowPoint": 5
      }
    },
    {
      "name": "Highlight Threshold (White Protection)",
      "priority": 70,
      "if": "maxL > 98",
      "then": {
        "highlightThreshold": 96
      }
    },
    {
      "name": "Cool-to-Neutral Protection",
      "priority": 950,
      "if": "sectors.blue.weight > 0.15 && global.neutralWeight > 0.10",
      "then": {
        "cWeight": 3.5,
        "useNeutralAnchoring": true,
        "neutralStiffness": 15.0,
        "description": "Increases chroma weighting and enables neutral anchoring to prevent blue bleeding into gray midtones"
      }
    }
  ]
}
