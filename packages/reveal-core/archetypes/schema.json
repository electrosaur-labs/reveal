{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Archetype Definition v2.0",
  "description": "Schema for defining image archetypes with target DNA v2.0 characteristics including 12-sector hue analysis.",
  "type": "object",
  "required": ["id", "name", "centroid", "parameters"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z_]+$",
      "description": "Unique identifier for the archetype (snake_case)"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name for the archetype"
    },
    "description": {
      "type": "string",
      "description": "Target image characteristics"
    },
    "preferred_sectors": {
      "type": "array",
      "description": "Optional: Hue sectors this archetype favors (e.g., ['blue', 'cyan'] for Blue Rescue)",
      "items": {
        "type": "string",
        "enum": ["red", "orange", "yellow", "chartreuse", "green", "cyan", "azure", "blue", "purple", "magenta", "pink", "rose"]
      }
    },
    "centroid": {
      "type": "object",
      "description": "Target DNA values defining the archetype's position in 7D feature space",
      "required": ["l", "c", "k", "l_std_dev", "hue_entropy", "temperature_bias", "primary_sector_weight"],
      "properties": {
        "l": { "type": "number", "minimum": 0, "maximum": 100, "description": "Target lightness" },
        "c": { "type": "number", "minimum": 0, "maximum": 150, "description": "Target chroma" },
        "k": { "type": "number", "minimum": 0, "maximum": 100, "description": "Target contrast" },
        "l_std_dev": { "type": "number", "minimum": 0, "maximum": 50, "description": "Target lightness variance" },
        "hue_entropy": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Target spectrum diversity (0=mono, 1=rainbow)"
        },
        "temperature_bias": {
          "type": "number",
          "minimum": -1,
          "maximum": 1,
          "description": "Target color temp (-1=cool, 1=warm)"
        },
        "primary_sector_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Target weight of the dominant 30° sector"
        }
      }
    },
    "weights": {
      "type": "object",
      "description": "Per-dimension weights for compatibility scoring",
      "properties": {
        "l": { "type": "number", "default": 1.0 },
        "c": { "type": "number", "default": 1.5 },
        "k": { "type": "number", "default": 2.0 },
        "l_std_dev": { "type": "number", "default": 1.0 },
        "hue_entropy": { "type": "number", "default": 2.0 },
        "temperature_bias": { "type": "number", "default": 1.5 },
        "primary_sector_weight": { "type": "number", "default": 2.5 }
      }
    },
    "parameters": {
      "type": "object",
      "description": "Processing parameters applied upon match",
      "required": [
        "targetColorsSlider", "lWeight", "cWeight", "blackBias",
        "vibrancyMode", "vibrancyBoost", "vibrancyThreshold",
        "enablePaletteReduction", "paletteReduction", "hueLockAngle",
        "enableHueGapAnalysis", "ditherType", "neutralSovereigntyThreshold"
      ],
      "properties": {
        "targetColorsSlider": { "type": "integer", "minimum": 1, "maximum": 16 },
        "lWeight": { "type": "number", "minimum": 0, "maximum": 5 },
        "cWeight": { "type": "number", "minimum": 0, "maximum": 10 },
        "blackBias": { "type": "number", "minimum": 0, "maximum": 10 },
        "vibrancyMode": { "type": "string", "enum": ["linear", "subtle", "moderate", "aggressive", "exponential"] },
        "vibrancyBoost": { "type": "number", "minimum": 0, "maximum": 3 },
        "vibrancyThreshold": { "type": "number", "minimum": 0, "maximum": 100 },
        "paletteReduction": { "type": "number", "minimum": 0, "maximum": 20 },
        "hueLockAngle": { "type": "number", "minimum": 0, "maximum": 90 },
        "neutralSovereigntyThreshold": { "type": "number", "minimum": 0, "maximum": 100 },
        "neutralCentroidClampThreshold": { "type": "number", "minimum": 0, "maximum": 20 },
        "ditherType": { "type": "string", "enum": ["BlueNoise", "Atkinson", "none"] },
        "shadowClamp": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Forces ink density between 0-N% up to exactly N%. Eliminates unprintable tints."
        },
        "chromaGate": {
          "type": "number",
          "minimum": 1.0,
          "maximum": 3.0,
          "description": "Multiplier for cWeight when DNA.maxC is high. Improves high-chroma color accuracy."
        },
        "detailRescue": {
          "type": "number",
          "minimum": 0,
          "maximum": 20,
          "description": "Reduces entropy noise floor by N points. Preserves small structural details."
        },
        "speckleRescue": {
          "type": "number",
          "minimum": 0,
          "maximum": 8,
          "description": "Morphological despeckle: removes isolated clusters below N pixels. Eliminates unprintable digital lint. Standard: 4 pixels for 230-mesh screens."
        },
        "medianPass": {
          "type": "boolean",
          "description": "Pre-posterization median filter (3×3): removes salt & pepper noise before palette generation. Essential for organic/sensor photos to prevent noise from becoming distinct colors. Disable for intentional halftone patterns."
        },
        "minVolume": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Palette post-pruning: merge colors with pixel coverage below N%. Resource allocation - weak colors (<minVolume) are merged to nearest neighbors. Prevents outlier/noise colors from claiming screens."
        }
      }
    }
  }
}
