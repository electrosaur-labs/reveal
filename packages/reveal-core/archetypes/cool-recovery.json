{
  "id": "cool_recovery",
  "version": "2.0.0",
  "name": "Cool Recovery",
  "group": "specialist",
  "engine": "direct",
  "description": "Forces engine to find cool-spectrum outliers in warm or neutral images.",
  "preferred_sectors": [
    "blue",
    "cyan",
    "azure"
  ],
  "centroid": {
    "l": 40,
    "c": 35,
    "k": 80,
    "l_std_dev": 22,
    "hue_entropy": 0.45,
    "temperature_bias": -0.6,
    "primary_sector_weight": 0.35
  },
  "weights": {
    "l": 1,
    "c": 2,
    "k": 2,
    "l_std_dev": 1.5,
    "temperature_bias": 2.5
  },
  "parameters": {
    "minColors": 4,
    "maxColors": 10,
    "ditherType": "atkinson",
    "distanceMetric": "cie2000",
    "lWeight": 1.5,
    "cWeight": "5.5 + Math.abs(image.dna.global.temperature_bias * 2)",
    "blackBias": 6.5,
    "vibrancyMode": "aggressive",
    "vibrancyBoost": "image.dna.global.hue_entropy < 0.4 ? 2.0 : 1.8",
    "highlightThreshold": 95,
    "highlightBoost": 1.2,
    "enablePaletteReduction": "image.dna.global.primary_sector_weight > 0.5",
    "paletteReduction": "image.dna.global.primary_sector_weight > 0.5 ? 4 : 0",
    "substrateMode": "auto",
    "substrateTolerance": 3.5,
    "shadowPoint": 10,
    "enableHueGapAnalysis": true,
    "hueLockAngle": 15,
    "colorMode": "color",
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "neutralSovereigntyThreshold": 0,
    "preprocessingIntensity": "light",
    "shadowClamp": "Math.max(6, press.mesh / 50)",
    "speckleRescue": 4,
    "medianPass": false,
    "minVolume": 1,
    "refinementPasses": 1
  },
  "scoring": {
    "chromaProfile": "moderate",
    "tonalRange": "dark",
    "expects_outlier": true
  }
}
