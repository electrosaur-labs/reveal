{
  "id": "silver_gelatin",
  "name": "Silver Gelatin / Tonal B&W",
  "description": "High-quality black-and-white photography with deep range and fine grain simulation.",
  "centroid": {
    "l": 50,
    "c": 2,
    "k": 85,
    "l_std_dev": 25
  },
  "weights": {
    "l": 1.5,
    "c": 2.0,
    "k": 1.5,
    "l_std_dev": 1.0
  },
  "parameters": {
    "engineType": "reveal",
    "centroidStrategy": "SALIENCY",
    "lWeight": 2.0,
    "cWeight": 0.5,
    "blackBias": 4.0,
    "substrateMode": "white",
    "substrateTolerance": 2.0,
    "vibrancyMode": "subtle",
    "vibrancyBoost": 0.5,
    "vibrancyThreshold": 5,
    "highlightThreshold": 92,
    "highlightBoost": 1.2,
    "enablePaletteReduction": true,
    "paletteReduction": 5.0,
    "hueLockAngle": 10,
    "shadowPoint": 5,
    "colorMode": "grayscale",
    "targetColorsSlider": 6,
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "enableHueGapAnalysis": false,
    "ditherType": "Atkinson",
    "maskProfile": "Gray Gamma 2.2"
  },
  "dna_constraints": [
    {
      "name": "THERMONUCLEAR: Achromatic Axis Lock",
      "priority": 1000,
      "if": "global.neutralWeight > 0.10 && global.chromaticCoverage > 0.30",
      "then": {
        "useAchromaticProjection": true,
        "hardNeutralLock": true,
        "neutralSovereigntyThreshold": 18.0,
        "neutralCentroidClampThreshold": 18.0,
        "lWeight": 40.0,
        "cWeight": 0.0,
        "blackBias": 6.0,
        "description": "Wide-Gate Isolation: Forces ALL low-saturation pixels (chroma < 18.0) to use L-only distance with 40.0× lightness weighting, preventing 'ghost swatches' like desaturated blue-pink grays from attracting fur pixels. Centroid clamping snaps weak-chroma clusters to pure gray."
      }
    },
    {
      "name": "Neutral Axis Hard-Lock (Fallback)",
      "priority": 990,
      "if": "global.neutralWeight > 0.05",
      "then": {
        "hardNeutralLock": true,
        "useNeutralGravity": true,
        "neutralStiffness": 35.0,
        "neutralDeadZone": 3.0,
        "neutralChromaThreshold": 3.5,
        "cWeight": 4.0,
        "description": "Hard-locks neutral centroids to a=0,b=0 and creates dead-zone to prevent pink/blue chatter"
      }
    },
    {
      "name": "Texture Preservation (High Entropy - Entropy King)",
      "priority": 90,
      "if": "l_std_dev > 20",
      "then": {
        "lWeight": 3.0,
        "ditherType": "BlueNoise",
        "blackBias": 5.0
      }
    },
    {
      "name": "Shadow Protection (Deep Blacks)",
      "priority": 80,
      "if": "minL < 5",
      "then": {
        "shadowPoint": 3,
        "blackBias": 6.0
      }
    },
    {
      "name": "High Contrast B&W",
      "priority": 85,
      "if": "k > 90",
      "then": {
        "lWeight": 3.0,
        "paletteReduction": 4.0,
        "hueLockAngle": 8
      }
    },
    {
      "name": "Highlight Detail (Bright Zones)",
      "priority": 75,
      "if": "maxL > 95",
      "then": {
        "highlightThreshold": 94,
        "highlightBoost": 1.5
      }
    }
  ]
}
