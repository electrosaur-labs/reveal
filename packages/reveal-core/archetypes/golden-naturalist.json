{
  "id": "golden_naturalist",
  "version": "1.0.0",
  "name": "Golden Naturalist",
  "group": "natural",
  "engine": "direct",
  "description": "Warm-toned painterly scenes with high hue diversity. Complex multi-hue compositions where many sectors contribute — landscapes, genre scenes, Art Nouveau illustrations. Higher entropy than Warm Dramatic; warmer than Subtle Naturalist.",
  "preferred_sectors": ["yellow", "orange", "chartreuse", "green", "cyan", "red"],
  "centroid": {
    "l": 65,
    "c": 17,
    "k": 90,
    "l_std_dev": 20,
    "hue_entropy": 0.62,
    "temperature_bias": 0.55,
    "primary_sector_weight": 0.40
  },
  "weights": {
    "l": 1.0,
    "c": 1.0,
    "k": 1.0,
    "l_std_dev": 1.0,
    "hue_entropy": 3.0,
    "temperature_bias": 0.5,
    "primary_sector_weight": 2.5
  },
  "parameters": {
    "minColors": 5,
    "maxColors": 10,
    "ditherType": "atkinson",
    "distanceMetric": "cie2000",
    "lWeight": 1.2,
    "cWeight": 2.5,
    "blackBias": 6,
    "vibrancyMode": "moderate",
    "vibrancyBoost": 1.3,
    "vibrancyThreshold": 12,
    "highlightThreshold": 95,
    "highlightBoost": 1.3,
    "enablePaletteReduction": true,
    "paletteReduction": 6,
    "substrateMode": "auto",
    "substrateTolerance": 2,
    "shadowPoint": 10,
    "enableHueGapAnalysis": true,
    "hueLockAngle": 15,
    "colorMode": "color",
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "maskProfile": "Gray Gamma 2.2",
    "neutralSovereigntyThreshold": 0,
    "neutralCentroidClampThreshold": 1,
    "preprocessingIntensity": "light",
    "shadowClamp": 4,
    "speckleRescue": 4,
    "minVolume": 1,
    "refinementPasses": 1
  }
}
