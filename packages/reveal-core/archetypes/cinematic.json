{
  "id": "cinematic",
  "version": "2.0.0",
  "name": "Cinematic",
  "group": "dramatic",
  "engine": "direct",
  "description": "Deep tones and heavy shadows. Prevents shadow fusion in low-exposure shots.",
  "preferred_sectors": [
    "blue",
    "cyan",
    "purple"
  ],
  "centroid": {
    "l": 40,
    "c": 25,
    "k": 65,
    "l_std_dev": 22,
    "hue_entropy": 0.55,
    "temperature_bias": -0.2,
    "primary_sector_weight": 0.25
  },
  "weights": {
    "l": 2,
    "c": 1.5,
    "k": 1,
    "l_std_dev": 2,
    "temperature_bias": 1.5
  },
  "parameters": {
    "minColors": 4,
    "maxColors": 10,
    "ditherType": "atkinson",
    "distanceMetric": "cie2000",
    "lWeight": 1.5,
    "cWeight": 2.5,
    "blackBias": "image.dna.global.k > 80 ? 9 : 7",
    "vibrancyMode": "aggressive",
    "vibrancyBoost": 1.3,
    "highlightThreshold": 85,
    "highlightBoost": "image.dna.global.temperature_bias < -0.3 ? 1.4 : 1.2",
    "enablePaletteReduction": true,
    "paletteReduction": 8,
    "substrateMode": "auto",
    "substrateTolerance": 2,
    "shadowPoint": "Math.max(2, 6 - (image.dna.global.l / 20))",
    "enableHueGapAnalysis": true,
    "hueLockAngle": 20,
    "colorMode": "color",
    "preserveWhite": true,
    "preserveBlack": true,
    "ignoreTransparent": true,
    "neutralSovereigntyThreshold": 5,
    "preprocessingIntensity": "heavy",
    "shadowClamp": "Math.max(4.0, press.mesh / 40)",
    "refinementPasses": 1
  },
  "scoring": {
    "chromaProfile": "low",
    "tonalRange": "dark",
    "expects_cool": true
  }
}
