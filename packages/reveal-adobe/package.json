{
  "name": "@reveal/adobe",
  "version": "0.13.0",
  "description": "Photoshop UXP plugin for screen print color separation using @reveal/core",
  "main": "dist/index.js",
  "scripts": {
    "build": "webpack --mode production && node scripts/copy-assets.js",
    "build:dev": "webpack --mode development && node scripts/copy-assets.js",
    "watch": "webpack --mode development --watch",
    "postbuild": "node scripts/copy-assets.js"
  },
  "dependencies": {
    "@reveal/core": "1.0.0"
  },
  "devDependencies": {
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "keywords": [
    "photoshop",
    "uxp",
