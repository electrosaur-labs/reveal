{
  "name": "@electrosaur-labs/navigator",
  "version": "1.0.0",
  "description": "Navigator UI for screen print color separation using @electrosaur-labs/core",
  "main": "dist/index.js",
  "scripts": {
    "build": "webpack --mode production && node scripts/copy-assets.js",
    "build:dev": "webpack --mode development && node scripts/copy-assets.js",
    "watch": "webpack --mode development --watch",
    "clean": "rm -rf dist",
    "package": "npm run build && node scripts/package.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@electrosaur-labs/core": "*",
    "buffer": "^6.0.3",
    "jpeg-js": "^0.4.4"
  },
  "devDependencies": {
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "keywords": [
    "photoshop",
    "uxp",
    "screen-printing",
    "color-separation",
    "navigator"
  ],
  "private": true,
  "author": "Electrosaur Labs",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/electrosaur-labs/reveal.git",
    "directory": "packages/reveal-navigator"
  }
}
