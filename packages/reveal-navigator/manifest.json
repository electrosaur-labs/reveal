{
  "id": "org.electrosaur.navigator",
  "name": "Navigator",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "23.3.0",
    "data": {
      "apiVersion": 2
    }
  },
  "manifestVersion": 5,
  "entrypoints": [
    {
      "type": "panel",
      "id": "navigator.panel",
      "label": {
        "default": "Navigator"
      },
      "minimumSize": { "width": 500, "height": 400 },
      "maximumSize": { "width": 3000, "height": 3000 },
      "preferredDockedSize": { "width": 900, "height": 700 },
      "preferredFloatingSize": { "width": 1100, "height": 850 }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "plugin",
    "network": {
      "domains": "all"
    },
    "clipboard": "readAndWrite"
  }
}
