{
  "id": "org.electrosaur.navigator",
  "name": "Electrosaur: Reveal",
  "version": "1.0.1",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "23.3.0",
    "data": {
      "apiVersion": 2
    }
  },
  "manifestVersion": 5,
  "entrypoints": [
    {
      "type": "command",
      "id": "navigator.showDialog",
      "label": {
        "default": "Reveal..."
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "plugin",
    "network": {
      "domains": "all"
    },
    "clipboard": "readAndWrite"
  }
}
