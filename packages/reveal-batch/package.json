{
  "name": "@reveal/batch",
  "version": "1.0.0",
  "description": "Command-line batch processing tool for screen print color separation using @reveal/core",
  "main": "src/index.js",
  "bin": {
    "reveal-batch": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "test": "echo \"No tests yet\" && exit 0",
    "reveal": "node src/reveal-batch.js",
    "reveal-preprocess": "node src/reveal-batch-preprocess.js",
    "analyze": "node src/analyze-batch.js",
    "convert-cq100": "node scripts/convertCQ100ToPsd.js",
    "profile-cq100": "node src/CQ100_Profiler.js",
    "generate-passports": "node src/CQ100_PassportGenerator.js",
    "architect-presets": "node src/PresetArchitect.js",
    "convert-ppm-to-tiff": "node src/convertPPMToLabTiff.js",
    "process-cq100": "node src/processCQ100.js",
    "process-8bit": "node src/process8bitPSD.js",
    "analyze-cq100": "node src/CQ100_MetaAnalyzer.js",
    "analyze-sp100": "node src/SP100_MetaAnalyzer.js",
    "revalidate": "node src/Revalidate.js",
    "revalidate-quality": "node src/RevalidateQuality.js",
    "analyze-dataset": "node src/DatasetArchitect.js",
    "test-astronaut": "node test-astronaut.js",
    "debug-ppm": "node debug-ppm.js",
    "debug-lab": "node debug-lab-conversion.js"
  },
  "dependencies": {
    "@reveal/core": "1.0.0",
    "@reveal/psd-reader": "1.0.0",
    "@reveal/psd-writer": "1.2.0",
    "ag-psd": "^29.1.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "sharp": "^0.33.0"
  },
  "keywords": [
    "cli",
    "batch-processing",
    "screen-printing",
    "color-separation",
    "image-processing"
  ],
  "author": "Electrosaur Labs",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=16.0.0"
  }
}
