{
  "name": "@electrosaur-labs/batch",
  "version": "1.0.0",
  "description": "Command-line batch processing tool for screen print color separation using @electrosaur-labs/core",
  "main": "src/index.js",
  "bin": {
    "reveal-batch": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "convert:cq100": "node src/convert-cq100.js",
    "convert:testimages": "node src/convert-testimages.js",
    "convert:sp100": "node src/convert-sp100.js",
    "benchmark:cq100": "node src/reveal-batch.js data/CQ100_v4/input/psd/8bit data/CQ100_v4/output/psd/8bit",
    "benchmark:testimages": "node src/reveal-batch.js data/TESTIMAGES/input/psd/16bit data/TESTIMAGES/output/psd/16bit",
    "benchmark:sp100:met": "node src/reveal-batch.js data/SP100/input/met/psd/16bit data/SP100/output/met/psd/16bit",
    "benchmark:sp100:rijks": "node src/reveal-batch.js data/SP100/input/rijks/psd/16bit data/SP100/output/rijks/psd/16bit",
    "benchmark:sp100:aic": "node src/reveal-batch.js data/SP100/input/aic/psd/16bit data/SP100/output/aic/psd/16bit",
    "benchmark:sp100:loc": "node src/reveal-batch.js data/SP100/input/loc/psd/16bit data/SP100/output/loc/psd/16bit",
    "benchmark:sp100:minkler": "node src/reveal-batch.js data/SP100/input/minkler/psd/16bit data/SP100/output/minkler/psd/16bit",
    "analyze:cq100": "node src/analyze-batch.js CQ100 data/CQ100_v4/output data/CQ100_v4/output/psd/8bit",
    "analyze:testimages": "node src/analyze-batch.js TESTIMAGES data/TESTIMAGES/output data/TESTIMAGES/output/psd/16bit",
    "analyze:sp100": "node src/analyze-batch.js SP100 data/SP100/output data/SP100/output/met/psd/16bit data/SP100/output/rijks/psd/16bit data/SP100/output/aic/psd/16bit data/SP100/output/loc/psd/16bit data/SP100/output/minkler/psd/16bit",
    "posterize": "node src/posterize-psd.js"
  },
  "dependencies": {
    "@electrosaur-labs/core": "*",
    "@electrosaur-labs/psd-reader": "*",
    "@electrosaur-labs/psd-writer": "*",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "sharp": "^0.33.0"
  },
  "keywords": [
    "cli",
    "batch-processing",
    "screen-printing",
    "color-separation",
    "image-processing"
  ],
  "author": "Electrosaur Labs",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/electrosaur-labs/reveal.git",
    "directory": "packages/reveal-batch"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "devDependencies": {
    "vitest": "^1.6.1"
  }
}
